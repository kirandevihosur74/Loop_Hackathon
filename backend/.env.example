# Copy to .env and fill. The loop runs WITHOUT a key (mock agent + mock data),
# so it demos keyless. Add the key for real Claude reasoning.

# --- Agent brain (Claude or a Claude-compatible gateway) --- empty key = mock brain
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=          # blank = api.anthropic.com; set to a gateway base (e.g. https://host/hax)
PLAN_MODEL=claude-haiku-4-5-20251001
ANALYSIS_MODEL=claude-sonnet-5

# --- Storage ---
DATABASE_URL=sqlite:///./loop.db

# --- Loop cadence ---
LOOP_CADENCE_MINUTES=60
ENABLE_SCHEDULER=false        # demo uses manual POST /loop/run

# --- Ingest ---
# Default = real CAISO OASIS prices (keyless). Set true to force the offline mock curve.
USE_MOCK_DATA=false
DEFAULT_ISO=CAISO             # CAISO | PJM | ERCOT | ...
CAISO_NODE=                   # blank = auto by household lat: TH_NP15_GEN-APND / TH_SP15_GEN-APND

# Sun/shade signal (SF shadow dataset → close-blinds / pre-cool nudges)
SHADOW_ENABLED=true
SHADOW_DATA_DIR=              # blank = repo datasets/shadow_data; in Docker set /app/datasets/shadow_data
# Nexla (sponsor) LIVE ingest — readings land in a Nexla nexset via a webhook source and the
# loop reads the newest record back through the authenticated API (service key → token →
# GET /data_sets/{nexset}/samples). Set the first three to make Nexla the live source; the
# feeder pushes readings in: python -m app.ingest.nexla_feed. See nexla/RESOURCES.local.md.
NEXLA_SERVICE_KEY=            # from express.dev; exchanged for a bearer token (Express Free = no credits)
NEXLA_API_URL=https://dataops.nexla.io/nexla-api
NEXLA_NEXSET_ID=             # dataset id the loop reads (blank/0 = Nexla off → CAISO direct)
NEXLA_INGEST_URL=            # webhook push URL (feeder POSTs readings here)
NEXLA_SINK_URL=              # legacy: unauthenticated GET returning latest row (optional)
GRIDSTATUS_API_KEY=          # optional secondary fallback for live LMP

# --- Nudge delivery via Zero.xyz (agent tool layer; pays per call in USDC on Base) ---
# Setup: npm i -g @zeroxyz/cli ; zero auth agent register --json ; zero wallet fund
# Two gates: both must be permissive to actually send an SMS (and wallet must be funded).
ZERO_ENABLED=false            # true = attempt delivery each cycle
ZERO_DRY_RUN=true             # true = build the CLI call but DON'T spend (safe demo)
ZERO_SMS_CAPABILITY=z_4Bd9DO.1  # Spraay SMS ($0.02/call); find others via `zero search`
ZERO_TARGET_PHONE=            # E.164 demo recipient, e.g. +14155552671
ZERO_MAX_PAY=0.05             # per-call USDC ceiling
ZERO_CLI=zero
