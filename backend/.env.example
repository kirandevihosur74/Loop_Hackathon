# Copy to .env and fill. The loop runs WITHOUT a key (mock agent + mock data),
# so it demos keyless. Add the key for real Claude reasoning.

# --- Agent brain (Claude API direct) ---
ANTHROPIC_API_KEY=
PLAN_MODEL=claude-haiku-4-5-20251001
ANALYSIS_MODEL=claude-sonnet-5

# --- Storage ---
DATABASE_URL=sqlite:///./loop.db

# --- Loop cadence ---
LOOP_CADENCE_MINUTES=60
ENABLE_SCHEDULER=false        # demo uses manual POST /loop/run

# --- Ingest ---
# Default = real CAISO OASIS prices (keyless). Set true to force the offline mock curve.
USE_MOCK_DATA=false
DEFAULT_ISO=CAISO             # CAISO | PJM | ERCOT | ...
CAISO_NODE=                   # blank = auto by household lat: TH_NP15_GEN-APND / TH_SP15_GEN-APND
NEXLA_SERVICE_KEY=
NEXLA_SINK_URL=               # http endpoint / file where Nexla lands latest rows (takes priority)
GRIDSTATUS_API_KEY=           # optional secondary fallback for live LMP

# --- Nudge delivery via Zero.xyz (agent tool layer; pays per call in USDC on Base) ---
# Setup: npm i -g @zeroxyz/cli ; zero auth agent register --json ; zero wallet fund
# Two gates: both must be permissive to actually send an SMS (and wallet must be funded).
ZERO_ENABLED=false            # true = attempt delivery each cycle
ZERO_DRY_RUN=true             # true = build the CLI call but DON'T spend (safe demo)
ZERO_SMS_CAPABILITY=z_4Bd9DO.1  # Spraay SMS ($0.02/call); find others via `zero search`
ZERO_TARGET_PHONE=            # E.164 demo recipient, e.g. +14155552671
ZERO_MAX_PAY=0.05             # per-call USDC ceiling
ZERO_CLI=zero
